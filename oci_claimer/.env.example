# ── OCI Identity ──────────────────────────────────────────────────────────────
# Found in OCI Console → Profile → Tenancy (top-right menu)
OCI_TENANCY_OCID=ocid1.tenancy.oc1..aaaaaaaa3zhwkdlevrocs5rqf35yqcyxo6eq7ovoi3dtgv7lwtdgxkrmfd4q

# Found in OCI Console → Profile → User Settings
OCI_USER_OCID=ocid1.user.oc1..aaaaaaaah6h7rovojhyri4ys7epq7esi5wd7ypublhhb6ehmd5ryvkx6yqoa

# Generated when you upload your API public key (see README)
OCI_FINGERPRINT=aa:bb:cc:dd:ee:ff:00:11:22:33:44:55:66:77:88:99

# Absolute path to your OCI API private key (.pem)
OCI_PRIVATE_KEY_PATH=/home/you/.oci/oci_api_key.pem

# ── OCI Placement ─────────────────────────────────────────────────────────────
# Target region (default: us-sanjose-1)
OCI_REGION=us-sanjose-1

# OCI Console → Identity → Compartments  (root compartment = tenancy OCID)
OCI_COMPARTMENT_OCID=ocid1.compartment.oc1..aaaa...

# OCI Console → Compute → Instances → Create Instance → Placement
# Format: <region-code>:AD-1  e.g. SJC-AD-1 or  US-SANJOSE-1-AD-1
OCI_AVAILABILITY_DOMAIN=IfZg:US-SANJOSE-1-AD-1

# OCI Console → Compute → Images → (choose an Oracle Linux or Ubuntu image)
OCI_IMAGE_OCID=ocid1.image.oc1.us-sanjose-1.aaaa...

# OCI Console → Networking → Virtual Cloud Networks → <your VCN> → Subnets
OCI_SUBNET_OCID=ocid1.subnet.oc1.us-sanjose-1.aaaa...

# ── Instance Shape ────────────────────────────────────────────────────────────
# Free-tier AMD micro (default — leave blank to use this)
OCI_SHAPE=VM.Standard.E2.1.Micro

# For Ampere ARM flex shape (VM.Standard.A1.Flex), uncomment and set these:
# OCI_SHAPE=VM.Standard.A1.Flex
# OCI_SHAPE_OCPUS=4
# OCI_SHAPE_MEMORY_GB=24

# ── Optional Instance Metadata ────────────────────────────────────────────────
# Paste the contents of your SSH public key here (single line)
# OCI_SSH_PUBLIC_KEY=ssh-rsa AAAA... you@host

# Human-readable name shown in the OCI Console
OCI_DISPLAY_NAME=oci-claimer-instance

# ── Polling ───────────────────────────────────────────────────────────────────
# How often to attempt a launch (seconds). Default: 60
POLL_INTERVAL_SECONDS=60

# Hard cap on exponential backoff (seconds). Default: 300
MAX_BACKOFF_SECONDS=300

# ── Telegram ──────────────────────────────────────────────────────────────────
# Same bot token already used by Gary
TELEGRAM_TOKEN=123456789:AABBccDDeeFFggHHiiJJkk...
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Logging ───────────────────────────────────────────────────────────────────
# Path to the local log file (default: oci_claimer.log in working directory)
LOG_FILE=oci_claimer.log
